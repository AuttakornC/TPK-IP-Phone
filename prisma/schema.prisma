// Wireless PA — multi-tenant SaaS schema
// learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// Enums
// ============================================================

enum Role {
  AUTHORITY
  OFFICER
  GENERAL

  @@map("role")
}

enum ProjectStatus {
  ACTIVE
  EXPIRING
  EXPIRED

  @@map("project_status")
}

enum LogType {
  EMERGENCY
  GROUP
  SINGLE
  SCHEDULED
  MP3

  @@map("log_type")
}

// Call state for a speaker — used to prevent overlapping broadcasts.
enum SpeakerStatus {
  IDLE
  BUSY

  @@map("speaker_status")
}

// ============================================================
// Tenant root
// ============================================================

model Project {
  id              String        @id @default(cuid())
  name            String
  status          ProjectStatus @default(ACTIVE)
  sipServerId     String        @map("sip_server_id")
  broadcastPrefix String        @default("") @map("broadcast_prefix")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  sipServer SipServer  @relation(fields: [sipServerId], references: [id], onDelete: Restrict)
  users     User[]
  speakers  Speaker[]
  logs      LogEntry[]
  schedules Schedule[]

  @@index([status])
  @@index([sipServerId])
  @@map("projects")
}

// Vendor-managed SIP server (PBX domain). Global — shared across projects.
// Every project's speakers + users register against exactly one server.
model SipServer {
  id        String   @id @default(cuid())
  name      String
  domain    String   @unique
  port      Int      @default(5060)
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  projects Project[]

  @@map("sip_servers")
}

// ============================================================
// Identity
// ============================================================

// Vendor-side operator. Separate auth surface from project users (see CLAUDE.md
// "admin namespace at /admin"); not scoped to any tenant.
model Admin {
  id           String    @id @default(cuid())
  name         String
  username     String    @unique
  passwordHash String?   @map("password_hash")
  active       Boolean   @default(true)
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@map("admins")
}

// Project-scoped user — exactly one project per user (no shared accounts).
// `sipExt` + `sipPassword` are the user's SIP credentials on their project's
// SIP server — admin-managed plaintext (CLAUDE.md), used by the browser to
// register before broadcasting.
model User {
  id           String    @id @default(cuid())
  name         String
  username     String    @unique
  passwordHash String?   @map("password_hash")
  role         Role
  active       Boolean   @default(true)
  lastLoginAt  DateTime? @map("last_login_at")
  projectId    String    @map("project_id")
  sipExt       String?   @unique @map("sip_ext")
  sipPassword  String?   @map("sip_password")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  project          Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignedSpeakers SpeakerAssignment[]
  logs             LogEntry[]
  mp3Files         Mp3File[]

  @@index([projectId])
  @@index([role])
  @@map("users")
}

// General-user ↔ speaker assignments (many-to-many).
model SpeakerAssignment {
  userId    String   @map("user_id")
  speakerId String   @map("speaker_id")
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  speaker Speaker @relation(fields: [speakerId], references: [id], onDelete: Cascade)

  @@id([userId, speakerId])
  @@index([speakerId])
  @@map("speaker_assignments")
}

// ============================================================
// Broadcast targets
// ============================================================

model Speaker {
  id        String        @id @default(cuid())
  projectId String        @map("project_id")
  name      String
  ext       String
  area      String
  online    Boolean       @default(false)
  status    SpeakerStatus @default(IDLE)
  volume    Int           @default(80)
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  project    Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignedTo SpeakerAssignment[]

  @@unique([projectId, ext])
  @@index([projectId])
  @@map("speakers")
}

// ============================================================
// Content + scheduling
// ============================================================

model Mp3File {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  name        String
  sizeBytes   BigInt   @map("size_bytes")
  durationSec Int      @map("duration_sec")
  storagePath String   @map("storage_path")
  uploadedAt  DateTime @default(now()) @map("uploaded_at")

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  schedules Schedule[]

  @@index([userId])
  @@map("mp3_files")
}

model Schedule {
  id           String   @id @default(cuid())
  projectId    String   @map("project_id")
  name         String
  cron         String
  target       String
  mp3FileId    String?  @map("mp3_file_id")
  enabled      Boolean  @default(true)
  skipHolidays Boolean  @default(false) @map("skip_holidays")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  project Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  mp3File Mp3File? @relation(fields: [mp3FileId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@map("schedules")
}

// ============================================================
// Audit log
// ============================================================

model LogEntry {
  id              String   @id @default(cuid())
  projectId       String   @map("project_id")
  userId          String?  @map("user_id")
  // Denormalized user label so history survives user deletion / "system" entries.
  userDisplayName String   @map("user_display_name")
  target          String
  durationSec     Int      @map("duration_sec")
  type            LogType
  recordingPath   String?  @map("recording_path")
  occurredAt      DateTime @default(now()) @map("occurred_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([projectId, occurredAt])
  @@index([userId])
  @@index([type])
  @@map("log_entries")
}

// ============================================================
// Global presets (shared across projects)
// ============================================================

model EmergencyPreset {
  id        String @id @default(cuid())
  code      String @unique
  name      String
  ext       String
  tonePath  String @map("tone_path")
  palette   String
  ttsScript String @map("tts_script")

  @@map("emergency_presets")
}

model Template {
  id          String @id @default(cuid())
  code        String @unique
  name        String
  icon        String
  filePath    String @map("file_path")
  durationSec Int    @map("duration_sec")

  @@map("templates")
}
